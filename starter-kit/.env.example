# Leave unset to run every adapter against its built-in example dataset —
# the server works out of the box with no credentials.

PORT=3000

# CRM adapter (generic REST, HubSpot/Pipedrive-shaped)
CRM_BASE_URL=
CRM_API_KEY=

# Internal DB adapter — the example ships in-memory; wire a real
# connection string in src/adapters/internal-db.example.ts (see comments
# there) and read it here, e.g. INTERNAL_DB_URL=postgres://...
INTERNAL_DB_URL=

# Generic API adapter
API_BASE_URL=
API_KEY=
